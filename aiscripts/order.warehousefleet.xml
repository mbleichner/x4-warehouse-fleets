<?xml version="1.0" encoding="utf-8"?>
<aiscript name="WarehouseFleet" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="/home/manuel/Nextcloud/X4 Foundations/2026-02-28/libraries/aiscripts.xsd" version="43">

  <order id="WarehouseFleet" name="WarehouseFleet" description="Warehouse Fleet" category="trade" infinite="true">
    <params>

      <!-- home warehouse -->
      <param name="sourceStation" required="true" type="object" text="Home Warehouse">
        <input_param name="class" value="[class.station]" />
        <input_param name="owner" value="this.ship.trueowner" />
      </param>

      <!-- targets -->
      <param name="targets" type="list" default="[]" text="Targets (all ships)">
        <input_param name="type" value="'object'" />
      </param>
      <param name="targetsL" type="list" default="[]" text="Targets (L only)">
        <input_param name="type" value="'object'" />
      </param>
      <param name="targetsM" type="list" default="[]" text="Targets (M only)">
        <input_param name="type" value="'object'" />
      </param>
      <param name="supplyTargets" type="list" default="[]" text="Supply Targets">
        <input_param name="type" value="'object'" />
        <patch sinceversion="38" value="[]" />
      </param>

      <!-- priorities and behavior -->
      <param name="prioDistribution" default="global.$WarehouseFleets.$prioDistribution" type="number" text="Prio: Distribute">
        <input_param name="min" value="0" />
        <input_param name="max" value="10" />
      </param>
      <param name="prioTrade" default="global.$WarehouseFleets.$prioTrade" type="number" text="Prio: Trade">
        <input_param name="min" value="0" />
        <input_param name="max" value="10" />
      </param>
      <param name="prioSupply" default="global.$WarehouseFleets.$prioSupply" type="number" text="Prio: Supply">
        <input_param name="min" value="0" />
        <input_param name="max" value="10" />
        <patch sinceversion="38" value="5" />
      </param>
      <param name="prioBuild" default="global.$WarehouseFleets.$prioBuild" type="number" text="Prio: Build">
        <input_param name="min" value="0" />
        <input_param name="max" value="10" />
        <patch sinceversion="42" value="7" />
      </param>
      <param name="minCargoUsage" default="global.$WarehouseFleets.$minCargoUsage" type="number" text="Min. Cargo Usage (%)">
        <input_param name="min" value="0" />
        <input_param name="max" value="90" />
        <patch sinceversion="43" value="[$minCargoUsage, 90].min" comment="reduced max value from 100 to 90" />
      </param>
      <param name="tradeGatePenalty" default="global.$WarehouseFleets.$tradeGatePenalty" type="number" text="Trade Gate Penalty (%)">
        <input_param name="min" value="0" />
        <input_param name="max" value="90" />
      </param>
      <param name="waitInDockS" type="bool" default="global.$WarehouseFleets.$waitInDockS" text="Dock idle S-sized ships">
        <patch sinceversion="43" value="global.$WarehouseFleets.$waitInDockS" />
      </param>
      <param name="waitInDockM" type="bool" default="global.$WarehouseFleets.$waitInDockM" text="Dock idle M-sized ships">
        <patch sinceversion="43" value="global.$WarehouseFleets.$waitInDockM" />
      </param>
      <param name="waitInDockL" type="bool" default="global.$WarehouseFleets.$waitInDockL" text="Dock idle L-sized ships">
        <patch sinceversion="43" value="global.$WarehouseFleets.$waitInDockL" />
      </param>
    </params>

    <requires>
      <match shiptype="shiptype.lasertower" negate="true" />
    </requires>
  </order>

  <interrupts>
    <handler ref="SectorChangeHandler" />
    <handler ref="AttackHandler" />
    <handler ref="MissileLockHandler" />
    <handler ref="ScannedHandler" />
    <handler ref="InspectedHandler" />
    <handler ref="FoundAbandonedHandler" />
    <handler ref="FoundLockboxHandler" />
    <handler ref="ResupplyHandler" />
    <handler ref="TargetInvalidHandler" />
    <handler ref="TideHandler" />
  </interrupts>

  <init>
    <set_order_syncpoint_reached order="this.assignedcontrolled.order" />
  </init>

  <attention min="unknown">
    <actions>
      <do_while value="true">

        <!-- inherit relevant parameters in assist mode, as they might have changed in the meantime -->
        <!-- (the scheduler takes all info from the $baseorder directly, so no need to inherit everything) -->
        <do_if value="this.ship.defaultorder.id == 'Assist'">
          <set_value name="$sourceStation" exact="this.ship.defaultorder.$baseorder.$sourceStation" />
          <set_value name="$waitInDockS" exact="this.ship.defaultorder.$baseorder.$waitInDockS" />
          <set_value name="$waitInDockM" exact="this.ship.defaultorder.$baseorder.$waitInDockM" />
          <set_value name="$waitInDockL" exact="this.ship.defaultorder.$baseorder.$waitInDockL" />
        </do_if>

        <!-- request scheduling -->
        <set_command_action commandaction="commandaction.searchingtrades" />
        <signal_objects object="player.entity" param="'WarehouseFleets'" param2="'RequestScheduling'" param3="this.ship" />

        <!-- if we get here, no job could be scheduled - determine what to do while waiting -->
        <set_value name="$waitInDock" exact="
            ($waitInDockS and this.ship.isclass.ship_s) or
            ($waitInDockM and this.ship.isclass.ship_m) or
            ($waitInDockL and (this.ship.isclass.ship_l or this.ship.isclass.ship_xl))
        " />
        <set_value name="$shouldDock" exact="$waitInDock and this.ship.dock == null" />
        <set_value name="$shouldUndock" exact="not $waitInDock and this.ship.dock != null" />

        <!-- dock/undock if necessary -->
        <do_if value="$shouldDock">
          <set_command_action commandaction="commandaction.docking" />
          <run_script name="'order.dock'">
            <param name="destination" value="$sourceStation" />
            <param name="trading" value="true" />
          </run_script>
        </do_if>
        <do_if value="$shouldUndock">
          <set_command_action commandaction="commandaction.undocking" />
          <run_script name="'move.undock'" />
        </do_if>

        <!-- wait some time, then retry scheduling -->
        <wait min="30s" max="60s" />

      </do_while>
    </actions>
  </attention>
</aiscript>