<?xml version="1.0" encoding="utf-8"?>
<mdscript name="WarehouseFleetsMenu" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="/home/manuel/Nextcloud/X4 Foundations/2026-02-28/libraries/md.xsd">
  <cues>
    <cue name="StartSMO" instantiate="true">
      <conditions>
        <event_cue_signalled cue="md.Simple_Menu_Options.Reloaded" />
      </conditions>
      <actions>
        <signal_cue_instantly cue="md.Simple_Menu_API.Register_Options_Menu"
          param="table[
            $id = 'WarehouseFleetsConfigMenu',
            $columns = 2,
            $title = {1223613, 36700},
            $onOpen = BuildWarehouseFleetConfigMenu,
          ]" />
        <cancel_cue cue="this" />
      </actions>
    </cue>
    <cue name="BuildWarehouseFleetConfigMenu" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" />
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={1223613, 36701}]" />
        <signal_cue_instantly
          cue="md.Simple_Menu_API.Make_Slider"
          param="table[
            $id = 'accountThreshold',
            $start = global.$WarehouseFleets.$accountThreshold,
            $col = 2,
            $text = table[$text=''],
            $min = 0, $max = 100, $suffix = 'M',
            $default = 1,
            $mouseOverText = {1223613, 46701},
            $onSliderCellConfirm = OnUpdateValue
          ]"
        />

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" />
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={1223613, 36702}]" />
        <signal_cue_instantly
          cue="md.Simple_Menu_API.Make_CheckBox"
          param="table[
            $id = 'transferToPlayer',
            $checked = global.$WarehouseFleets.$transferToPlayer,
            $col = 2,
            $width = 'Helper.standardButtonHeight', 
            $height = 'Helper.standardButtonHeight',
            $default = false,
            $mouseOverText = {1223613, 46702},
            $onClick = OnUpdateCheckbox
          ]"
        />

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" />
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={1223613, 36706}]" />
        <signal_cue_instantly
          cue="md.Simple_Menu_API.Make_Dropdown"
          param="table[
              $id = 'failedOrderHandling',
              $col = 2,
              $options = [
                table[$text={1223613, 36707}, $value=1],
                table[$text={1223613, 36708}, $value=2],
                table[$text={1223613, 36709}, $value=3],
                table[$text={1223613, 36710}, $value=4],
                table[$text={1223613, 36711}, $value=5]
              ],
              $startOption = global.$WarehouseFleets.$failedOrderHandling,
              $mouseOverText = {1223613, 46706} + 
                               {1223613, 46707} +
                               {1223613, 46708} +
                               {1223613, 46709} +
                               {1223613, 46710} +
                               {1223613, 46711},
              $onDropDownConfirmed = OnUpdateDropdown
          ]" />


        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" />
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={1223613, 36703}]" />
        <signal_cue_instantly
          cue="md.Simple_Menu_API.Make_CheckBox"
          param="table[
            $id = 'waitInDockS',
            $checked = global.$WarehouseFleets.$waitInDockS,
            $col = 2,
            $width = 'Helper.standardButtonHeight',
            $height = 'Helper.standardButtonHeight',
            $default = false,
            $mouseOverText = {1223613, 46703},
            $onClick = OnUpdateCheckbox
          ]"
        />

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" />
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={1223613, 36704}]" />
        <signal_cue_instantly
          cue="md.Simple_Menu_API.Make_CheckBox"
          param="table[
            $id = 'waitInDockM',
            $checked = global.$WarehouseFleets.$waitInDockM,
            $col = 2,
            $width = 'Helper.standardButtonHeight',
            $height = 'Helper.standardButtonHeight',
            $default = false,
            $mouseOverText = {1223613, 46704},
            $onClick = OnUpdateCheckbox
          ]"
        />

        <signal_cue_instantly cue="md.Simple_Menu_API.Add_Row" />
        <signal_cue_instantly cue="md.Simple_Menu_API.Make_Text" param="table[$col=1, $text={1223613, 36705}]" />
        <signal_cue_instantly
          cue="md.Simple_Menu_API.Make_CheckBox"
          param="table[
            $id = 'waitInDockL',
            $checked = global.$WarehouseFleets.$waitInDockL,
            $col = 2,
            $width = 'Helper.standardButtonHeight',
            $height = 'Helper.standardButtonHeight',
            $default = false,
            $mouseOverText = {1223613, 46705},
            $onClick = OnUpdateCheckbox
          ]"
        />

      </actions>
    </cue>

    <cue name="OnUpdateCheckbox" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <set_value name="global.$WarehouseFleets.{'$' + event.param.$id}" exact="event.param.$checked" />
      </actions>
    </cue>
    <cue name="OnUpdateDropdown" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <set_value name="global.$WarehouseFleets.{'$' + event.param.$id}" exact="event.param.$option.$value" />
      </actions>
    </cue>
    <cue name="OnUpdateValue" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <set_value name="global.$WarehouseFleets.{'$' + event.param.$id}" exact="event.param.$value" />
      </actions>
    </cue>

  </cues>
</mdscript>